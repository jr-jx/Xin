# ============================================================
# EdgeOne Pages KV
# 线上需在 EdgeOne Pages 绑定两个 KV：
# - XIN_COMMENTS_KV：评论、评论点赞、评论限流
# - XIN_FRIENDS_KV：朋友圈聚合缓存、朋友圈点赞
# - EDGE_KV_PROXY_SECRET：Nuxt 服务端调用 Edge Function KV 代理的内部密钥
# 本地开发会使用 .data/edgeone-kv 模拟
# ============================================================
EDGE_KV_PROXY_SECRET=

# ============================================================
# 朋友圈点赞
# ============================================================
NUXT_IP_HASH_SALT=xin-friends-likes-v1

# ============================================================
# 内置评论系统（EdgeOne KV 存储）
# ============================================================
NUXT_COMMENT_ADMIN_PASSWORD=
NUXT_COMMENT_JWT_SECRET=
NUXT_COMMENT_NOTIFY_TO=
NUXT_COMMENT_KEYWORD_BLACKLIST=

# ============================================================
# 邮件服务（评论通知，SMTPS 默认 465）
# ============================================================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
