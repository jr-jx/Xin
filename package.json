{
  "name": "@everfu/xin",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint:fix": "eslint --fix && stylelint '**/*.{vue,scss}' --fix",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@nuxt/content": "catalog:content",
    "@nuxt/eslint": "catalog:quality",
    "@nuxt/icon": "catalog:ui",
    "@nuxt/image": "catalog:ui",
    "@nuxtjs/color-mode": "catalog:ui",
    "@pinia/nuxt": "catalog:util",
    "@shikijs/colorized-brackets": "catalog:content",
    "@shikijs/transformers": "catalog:content",
    "@types/node": "catalog:framework",
    "@vueuse/core": "catalog:util",
    "@vueuse/motion": "catalog:ui",
    "@zinkawaii/stylelint-config": "catalog:quality",
    "ci-info": "catalog:util",
    "date-fns": "catalog:util",
    "fast-xml-parser": "catalog:util",
    "isomorphic-dompurify": "catalog:comment",
    "marked": "catalog:comment",
    "nodemailer": "catalog:comment",
    "nuxt": "catalog:framework",
    "pinia": "catalog:util",
    "sass-embedded": "catalog:framework",
    "stylelint": "catalog:quality",
    "unplugin-yaml": "catalog:util",
    "vue": "catalog:framework",
    "vue-router": "catalog:framework",
    "vue-tippy": "catalog:ui",
    "zod": "catalog:content"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:quality",
    "@iconify-json/ant-design": "catalog:ui",
    "@iconify-json/devicon": "catalog:ui",
    "@iconify-json/icon-park-solid": "catalog:ui",
    "@iconify-json/material-symbols": "catalog:ui",
    "@iconify-json/mdi": "catalog:ui",
    "@iconify-json/mynaui": "catalog:ui",
    "@iconify-json/ph": "catalog:ui",
    "@iconify-json/ri": "catalog:ui",
    "@iconify-json/simple-icons": "catalog:ui",
    "@iconify-json/skill-icons": "catalog:ui",
    "@iconify-json/solar": "catalog:ui",
    "@iconify-json/tabler": "catalog:ui",
    "@iconify-json/twemoji": "catalog:ui",
    "@types/nodemailer": "catalog:comment",
    "better-sqlite3": "catalog:content",
    "eslint": "catalog:quality",
    "lint-staged": "catalog:",
    "rehype-katex": "catalog:content",
    "remark-math": "catalog:content",
    "remark-reading-time": "catalog:content",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:framework"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix"
    ],
    "*.{scss,vue}": [
      "stylelint --fix"
    ]
  }
}